# Lab environment configuration
# Edit these values before running lab-setup.sh

# ============================================================================
# NetBird
# ============================================================================
# Path to your NetBird repo clone (optional — auto-detected if not set)
# Clone with: git clone https://github.com/netbirdio/netbird.git ~/netbird
# NETBIRD_REPO="~/netbird"

# Domain Traefik routes traffic to — must match a DNS A record pointing at this server.
# All NetBird router Host() rules and the wildcard TLS cert (*.base-domain) are built
# from this value.  Use a subdomain (e.g. netbird.example.com), not the bare root domain,
# unless you intend NetBird to own the apex.
NETBIRD_DOMAIN="netbird.example.au"
REVERSE_PROXY_TYPE="0"
TRAEFIK_ACME_EMAIL="admin@example.com"
ENABLE_PROXY="false"

# Set to 1 to use Let's Encrypt STAGING CA instead of production.
# Staging has no rate limits but issues certs that browsers don't trust (expected).
# Use when doing repeated teardown/rebuild cycles to avoid the 5-certs-per-week limit.
# Switch back to production (ACME_STAGING=0 or unset) when the setup is stable.
# ACME_STAGING=0

# ============================================================================
# PostgreSQL (shared by NetBird + eventsproc)
# ============================================================================
POSTGRES_USER="netbird"
POSTGRES_PASSWORD="netbird-lab-pass"
POSTGRES_DB="netbird"
POSTGRES_PORT="5432"

# ============================================================================
# Eventsproc
# ============================================================================
EP_PLATFORM="sandbox"
EP_REGION="apac"
EP_LOG_LEVEL="debug"
EP_BATCH_SIZE="100"
EP_POLLING_INTERVAL="30"
EP_METRICS_PORT="2113"
EP_EMAIL_ENRICHMENT_SOURCE="netbird_users"

# Path to NetBird's config.yaml inside the eventsproc container.
# Used to read server.store.encryptionKey for AES-GCM decryption of
# email/name fields (NetBird encrypts these columns at rest).
# Auto-set to /etc/netbird/config.yaml in real NetBird mode (LAB_MODE=2).
# Leave unset for simulated mode — stub data is not encrypted.
# EP_NETBIRD_CONFIG_PATH="/etc/netbird/config.yaml"

# Database driver: "postgres" (default) or "sqlite"
# Set via lab-setup.sh prompt, or override here to skip the prompt
# EP_DATABASE_DRIVER="postgres"

# ============================================================================
# Grafana
# ============================================================================
GRAFANA_PORT="3000"
GRAFANA_ADMIN_PASSWORD="admin"

# ============================================================================
# Loki
# ============================================================================
LOKI_PORT="3100"

# ============================================================================
# Splunk
# ============================================================================
SPLUNK_PORT="8000"
SPLUNK_HEC_PORT="8088"
SPLUNK_HEC_TOKEN="lab-hec-token-123"
SPLUNK_PASSWORD="changeme123"
